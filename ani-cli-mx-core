source_status() {
    case "$2" in
        ok) printf "\033[1;32m%s\033[0m Links Fetched\n" "$1" 1>&2 ;;
        fallback) printf "\033[1;33m%s\033[0m Fallback Only\n" "$1" 1>&2 ;;
        skip) printf "\033[1;31m%s\033[0m No Valid Link\n" "$1" 1>&2 ;;
        disabled) : ;;
    esac
}

probe_stream_link() {
    headers="$(curl -I -L --connect-timeout 10 --max-time "$resolver_timeout" -s -e "$1" "$2" -A "$agent")" || return 1
    printf '%s' "$headers" | grep -qiE '^content-type: (video/|application/vnd\.apple\.mpegurl|application/x-mpegurl)'
}

find_link_referrer() {
    printf '%s\n' "$1" | awk -F'>' -v ep="$2" '$1=="referrer " && $2==ep { print $3; exit }'
}

find_link_source() {
    printf '%s\n' "$1" | awk -F'>' -v ep="$2" '$1=="source " && $2==ep { print $3; exit }'
}

find_link_site() {
    printf '%s\n' "$1" | awk -F'>' -v ep="$2" '$1=="site " && $2==ep { print $3; exit }'
}

describe_link_origin() {
    if [ -n "$1" ] && [ -n "$2" ]; then
        [ "$1" = "$2" ] && printf '%s' "$1" || printf '%s / %s' "$1" "$2"
        return 0
    fi
    [ -n "$1" ] && printf '%s' "$1" && return 0
    [ -n "$2" ] && printf '%s' "$2" && return 0
    return 1
}

count_quality_links() {
    printf '%s\n' "$1" | grep -cE '^[0-9]{3,4} >'
}

find_link_quality() {
    printf '%s\n' "$1" | awk -F'>' -v ep="$2" '$1 ~ /^[0-9]{3,4} / && $2==ep { sub(/[[:space:]]+$/, "", $1); print $1; exit }'
}

emit_annotated_link_entry() {
    entry_url="$(printf '%s' "$1" | cut -d'>' -f2)"
    [ -z "$entry_url" ] && entry_url="$1"
    printf '%s\n' "$1"
    [ -n "$2" ] && printf 'source >%s>%s\n' "$entry_url" "$2"
    [ -n "$3" ] && printf 'site >%s>%s\n' "$entry_url" "$3"
}

quality_menu_entries() {
    old_ifs=$IFS
    IFS='
'
    menu_index=1
    for entry in $1; do
        printf '%s' "$entry" | grep -qE '^[0-9]{3,4} >' || continue
        candidate_quality="$(printf '%s' "$entry" | cut -d'>' -f1)"
        candidate_url="$(printf '%s' "$entry" | cut -d'>' -f2)"
        candidate_site="$(find_link_site "$1" "$candidate_url")"
        candidate_source="$(find_link_source "$1" "$candidate_url")"
        origin_label="$(describe_link_origin "$candidate_site" "$candidate_source")"
        [ -n "$origin_label" ] && printf '%s\t%s\t%s\n' "$menu_index" "$candidate_quality" "$origin_label" ||
            printf '%s\t%s\t%s\n' "$menu_index" "$candidate_quality" "Desconocida"
        menu_index=$((menu_index + 1))
    done
    IFS=$old_ifs
}

available_site_entries() {
    menu_index=1
    for site_name in AnimeFLV JKAnime AnimeAV1; do
        case "$site_name" in
            AnimeFLV) site_links="$1" ;;
            JKAnime) site_links="$2" ;;
            AnimeAV1) site_links="$3" ;;
        esac
        site_count="$(count_quality_links "$site_links")"
        [ "$site_count" -gt 0 ] || continue
        printf '%s\t%s\t%s (%s enlaces)\n' "$menu_index" "$site_name" "$site_name" "$site_count"
        menu_index=$((menu_index + 1))
    done
}

set_links_for_site() {
    case "$1" in
        AnimeFLV) links="$animeflv_links" ;;
        JKAnime) links="$jkanime_links" ;;
        AnimeAV1) links="$animeav1_links" ;;
        *) return 1 ;;
    esac
    selected_spanish_site="$1"
    preferred_spanish_site="$1"
    return 0
}

pick_spanish_source_links() {
    site_options="$(available_site_entries "$1" "$2" "$3")"
    available_sites="$(printf '%s\n' "$site_options" | sed '/^$/d')"
    [ -z "$available_sites" ] && return 1

    if [ -n "$preferred_spanish_site" ] && printf '%s\n' "$available_sites" | cut -f2 | grep -Fxq "$preferred_spanish_site"; then
        selected_spanish_site="$preferred_spanish_site"
    else
        site_count="$(printf '%s\n' "$available_sites" | wc -l | tr -d '[:space:]')"
        if [ "$site_count" -eq 1 ]; then
            selected_spanish_site="$(printf '%s\n' "$available_sites" | cut -f2)"
        else
            selected_spanish_site="$(printf '%s\n' "$available_sites" | nth "Selecciona fuente: " | cut -f1)"
        fi
    fi

    case "$selected_spanish_site" in
        AnimeFLV) set_links_for_site "AnimeFLV" ;;
        JKAnime) set_links_for_site "JKAnime" ;;
        AnimeAV1) set_links_for_site "AnimeAV1" ;;
        *) return 1 ;;
    esac
    return 0
}

link_is_probably_broken() {
    case "$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')" in
        *novideo* | *no-video* | *no_video* | *video_not_found* | *404.mp4* | *404.m3u8*) return 0 ;;
        *) return 1 ;;
    esac
}

select_ytdlp_url() {
    old_ifs=$IFS
    IFS='
'
    for candidate_url in $1; do
        [ -z "$candidate_url" ] && continue
        printf '%s' "$candidate_url" | grep -qE '^https?://' || continue
        link_is_probably_broken "$candidate_url" && continue
        printf '%s\n' "$candidate_url"
        IFS=$old_ifs
        return 0
    done
    IFS=$old_ifs
    return 1
}

probe_link_with_mpv() {
    probe_referrer=""
    [ -n "$2" ] && probe_referrer="--referrer=$2"

    # Probe candidates with a silent one-frame decode, so only actually playable
    # sources survive selection.
    case "$player_function" in
        flatpak_mpv)
            timeout "${probe_timeout}s" flatpak run io.mpv.Mpv --no-config --ao=null --vo=null --frames=1 \
                --really-quiet $probe_referrer "$1" >/dev/null 2>&1
            ;;
        mpv.exe | */mpv.exe)
            timeout "${probe_timeout}s" "$player_function" --no-config --ao=null --vo=null --frames=1 \
                --really-quiet $probe_referrer "$1" >/dev/null 2>&1
            ;;
        mpv | */mpv)
            timeout "${probe_timeout}s" "$player_function" --no-config --ao=null --vo=null --frames=1 \
                --really-quiet $probe_referrer "$1" >/dev/null 2>&1
            ;;
        *)
            if command -v mpv >/dev/null 2>&1; then
                timeout "${probe_timeout}s" mpv --no-config --ao=null --vo=null --frames=1 \
                    --really-quiet $probe_referrer "$1" >/dev/null 2>&1
            elif command -v flatpak >/dev/null 2>&1 && flatpak info io.mpv.Mpv >/dev/null 2>&1; then
                timeout "${probe_timeout}s" flatpak run io.mpv.Mpv --no-config --ao=null --vo=null --frames=1 \
                    --really-quiet $probe_referrer "$1" >/dev/null 2>&1
            else
                return 0
            fi
            ;;
    esac
}

