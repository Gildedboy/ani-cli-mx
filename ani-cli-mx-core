prefix_search_results() {
    site_name="$1"
    old_ifs=$IFS
    IFS='
'
    for entry in $2; do
        result_id="$(printf '%s' "$entry" | cut -f1)"
        result_title="$(printf '%s' "$entry" | cut -f2)"
        [ -z "$result_id" ] && continue
        [ -z "$result_title" ] && continue
        printf '%s:%s\t%s\t%s [%s]\n' "$site_name" "$result_id" "$result_title" "$result_title" "$(info_source_label "$site_name")"
    done
    IFS=$old_ifs
}

prefix_allanime_search_results() {
    old_ifs=$IFS
    IFS='
'
    for entry in $1; do
        result_id="$(printf '%s' "$entry" | cut -f1)"
        result_title="$(printf '%s' "$entry" | cut -f2)"
        result_count="$(printf '%s' "$entry" | cut -f3)"
        [ -z "$result_id" ] && continue
        [ -z "$result_title" ] && continue
        [ -z "$result_count" ] && continue
        printf 'allanime:%s|%s\t%s\t%s [%s]\n' "$result_id" "$result_count" "$result_title" "$result_title" "$(info_source_label "allanime")"
    done
    IFS=$old_ifs
}

normalize_info_source() {
