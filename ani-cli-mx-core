search_allanime_fallback() {
    search_gql='query( $search: SearchInput $limit: Int $page: Int $translationType: VaildTranslationTypeEnumType $countryOrigin: VaildCountryOriginEnumType ) { shows( search: $search limit: $limit page: $page translationType: $translationType countryOrigin: $countryOrigin ) { edges { _id name availableEpisodes __typename } }}'

    curl -e "$english_source_refr" -s -H "Content-Type: application/json" -X POST "${english_source_api}/api" \
        --data "{\"variables\":{\"search\":{\"allowAdult\":false,\"allowUnknown\":false,\"query\":\"$1\"},\"limit\":40,\"page\":1,\"translationType\":\"$mode\",\"countryOrigin\":\"ALL\"},\"query\":\"$search_gql\"}" \
        -A "$agent" | sed 's|Show|\
|g' | sed -nE "s|.*_id\":\"([^\"]*)\",\"name\":\"(.+)\",.*${mode}\":([1-9][^,]*).*|\1\t\2 (\3 episodes)|p" | sed 's/\\"//g'
}

search_allanime_catalog() {
    search_allanime_fallback "$1" | sed -nE 's|^([^\t]+)\t(.*) \(([0-9]+) episodes\)$|\1\t\2\t\3|p'
}

select_allanime_ref() {
    cache_key="$1|$id"
    [ "$allanime_fallback_ref_key" = "$cache_key" ] && [ -n "$allanime_fallback_ref" ] && printf '%s\n' "$allanime_fallback_ref" && return 0

    explicit_allanime_id="$(allanime_id_from_ref "$id")"
    explicit_allanime_count="$(allanime_count_from_ref "$id")"
    if [ -n "$explicit_allanime_id" ] && [ -n "$explicit_allanime_count" ]; then
        allanime_fallback_ref="${explicit_allanime_id}|${explicit_allanime_count}"
        allanime_fallback_ref_key="explicit:$id"
        printf '%s\n' "$allanime_fallback_ref"
        return 0
    fi

    fallback_results="$(search_allanime_catalog "$1")"
    [ -z "$fallback_results" ] && return 1

    best_ref=""
    best_score=-999999
    old_ifs=$IFS
    IFS='
'
    for entry in $fallback_results; do
        candidate_id="$(printf '%s' "$entry" | cut -f1)"
        candidate_title="$(printf '%s' "$entry" | cut -f2)"
        candidate_count="$(printf '%s' "$entry" | cut -f3)"
        [ -z "$candidate_id" ] && continue
        [ -z "$candidate_count" ] && continue
        score="$(title_match_score "$1" "$candidate_id" "$candidate_title")"
        [ "$score" -gt "$best_score" ] && best_score="$score" && best_ref="${candidate_id}|${candidate_count}"
    done
    IFS=$old_ifs

    cross_source_match_is_confident "$best_score" || return 1
    [ -z "$best_ref" ] && best_ref="$(printf '%s\n' "$fallback_results" | sed -n '1p' | cut -f1,3 | tr '\t' '|')"
    [ -z "$best_ref" ] && return 1

    allanime_fallback_ref="$best_ref"
    allanime_fallback_ref_key="$cache_key"
    printf '%s\n' "$allanime_fallback_ref"
}

select_allanime_id() {
    allanime_ref="$(select_allanime_ref "$1")" || return 1
    printf '%s\n' "${allanime_ref%%|*}"
}

resolve_allanime_episode() {
    fallback_id="$(select_allanime_id "$1")" || return 1
    episode_embed_gql='query ($showId: String!, $translationType: VaildTranslationTypeEnumType!, $episodeString: String!) { episode( showId: $showId translationType: $translationType episodeString: $episodeString ) { episodeString sourceUrls }}'

    api_resp="$(curl -e "$english_source_refr" -s -H "Content-Type: application/json" -X POST "${english_source_api}/api" \
        --data "{\"variables\":{\"showId\":\"$fallback_id\",\"translationType\":\"$mode\",\"episodeString\":\"$2\"},\"query\":\"$episode_embed_gql\"}" -A "$agent")"
    if printf "%s" "$api_resp" | grep -q '"tobeparsed"'; then
        blob="$(printf "%s" "$api_resp" | sed -nE 's|.*"tobeparsed":"([^"]*)".*|\1|p')"
        resp="$(decode_tobeparsed "$blob")"
    else
        resp="$(printf "%s" "$api_resp" | tr '{}' '\n' | sed 's|\\u002F|\/|g;s|\\||g' | sed -nE 's|.*sourceUrl":"--([^"]*)".*sourceName":"([^"]*)".*|\2 :\1|p')"
    fi
    [ -z "$resp" ] && return 1

    cache_dir="$(mktemp -d)"
    providers="1 2 3 4"
    for provider in $providers; do
        allanime_generate_link "$provider" >"$cache_dir"/"$provider" &
    done
    wait
    links="$(cat "$cache_dir"/* | sort -g -r -s)"
    rm -r "$cache_dir"
    [ -n "$links" ] && printf '%s' "$links"
}

pick_animeflv_language() {
    case "$mode" in
        dub)
            for lang in LAT ESP SUB; do
                printf '%s' "$1" | grep -q "\"$lang\":\\[" && printf '%s\n' "$lang" && return 0
            done
            ;;
        *)
            for lang in SUB ESP LAT; do
                printf '%s' "$1" | grep -q "\"$lang\":\\[" && printf '%s\n' "$lang" && return 0
            done
            ;;
    esac
    return 1
}

extract_animeflv_links() {
    lang_entries="$(printf '%s' "$1" | tr -d '\n' | sed "s|.*\"$2\":\\[||" | sed 's|],"[A-Z][A-Z][A-Z]":.*||; s|]}$||; s|},{|}\
{|g')"
    primary_links=""
    fallback_links=""
    old_ifs=$IFS
    IFS='
'
    for entry in $lang_entries; do
        [ -z "$entry" ] && continue
        server="$(printf '%s' "$entry" | sed -nE 's|.*"server":"([^"]*)".*|\1|p')"
        code="$(printf '%s' "$entry" | sed -nE 's|.*"code":"([^"]*)".*|\1|p' | sed 's|\\\/|/|g;s|\\"|"|g')"
        [ -z "$code" ] && continue

        server_name="$(source_label "$server")"
        direct_link=""
        case "$server" in
            mega)
                :
                ;;
            netu)
                :
                ;;
            stape)
                direct_link="$(extract_streamtape_link "$code")"
                if [ -n "$direct_link" ] && probe_stream_link "$code" "$direct_link"; then
                    primary_links="${primary_links}880 >${direct_link}
source >${direct_link}>${server_name}
site >${direct_link}>AnimeFLV
"
                    source_status "$server_name" "ok"
                else
                    source_status "$server_name" "skip"
                fi
                ;;
            yu)
                direct_link="$(extract_yourupload_link "$code")"
                if [ -n "$direct_link" ] && probe_link_with_mpv "$direct_link" "$code"; then
                    primary_links="${primary_links}910 >${direct_link}
referrer >${direct_link}>${code}
source >${direct_link}>${server_name}
site >${direct_link}>AnimeFLV
"
                    source_status "$server_name" "ok"
                else
                    source_status "$server_name" "skip"
                fi
                ;;
            *)
                direct_link="$(extract_with_ytdlp "$code")"
                if [ -n "$direct_link" ]; then
                    case "$server" in
                        sw) priority="880" ;;
                        mega) priority="860" ;;
                        *) priority="480" ;;
                    esac
                    primary_links="${primary_links}${priority} >${direct_link}
source >${direct_link}>${server_name}
site >${direct_link}>AnimeFLV
"
                    source_status "$server_name" "ok"
                else
                    source_status "$server_name" "skip"
                fi
                ;;
        esac
    done
    IFS=$old_ifs

    if [ -n "$primary_links" ]; then
        printf '%s' "$primary_links"
    else
        printf '%s' "$fallback_links"
    fi
}

select_quality() {
    # removing urls which have soft subs to avoid playing on android, iSH and vlc (m3u8 streams don't get correct referrer)
    printf '%s' "$player_function" | cut -f1 -d" " | grep -qE '(android|iSH|vlc)' && links=$(printf '%s' "$links" | sed '/cc>/d;/subtitle >/d;/m3u8_refr >/d')
    printf '%s' "$player_function" | cut -f1 -d" " | grep -qE '(android|iSH)' && links=$(printf '%s' "$links" | sed '/Yt >/d')
    requested_quality="$(printf '%s' "$1" | sed 's|p$||')"
    case "$1" in
        best) result=$(printf "%s" "$links" | grep -E '^[0-9]{3,4} >' | head -n1) ;;
        worst) result=$(printf "%s" "$links" | grep -E '^[0-9]{3,4}' | tail -n1) ;;
        *) result=$(printf "%s" "$links" | grep -E "^[0-9]{3,4} >" | grep -m 1 "^${requested_quality} >") ;;
    esac
    [ -z "$result" ] && printf "La calidad especificada no existe, usando la mejor disponible\n" 1>&2 &&
        result=$(printf "%s" "$links" | grep -E '^[0-9]{3,4} >' | head -n1)

    # add refr,sub flags for m3u8 and refr flag for yt
    printf '%s' "$result" | grep -q "cc>" && subtitle="$(printf '%s' "$links" | sed -nE 's|subtitle >(.*)|\1|p')" &&
        [ -n "$subtitle" ] && subs_flag="--sub-file=$subtitle"
    printf "%s" "$result" | grep -q "tools.fast4speed.rsvp" && refr_flag="--referrer=$allanime_refr"
    episode=$(printf "%s" "$result" | cut -d'>' -f2)
    selected_quality="$(printf '%s' "$result" | cut -d'>' -f1 | tr -d '[:space:]')"
    generic_refr="$(printf '%s\n' "$links" | awk -F'>' -v ep="$episode" '$1=="referrer " && $2==ep { print $3; exit }')"
    selected_site="$(find_link_site "$links" "$episode")"
    selected_source="$(find_link_source "$links" "$episode")"
    selected_origin="$(describe_link_origin "$selected_site" "$selected_source")"
    [ -n "$generic_refr" ] && refr_flag="--referrer=$generic_refr"

    ! (printf '%s' "$result" | grep -qE "(cc>|tools.fast4speed.rsvp)") && unset refr_flag
    [ -n "$generic_refr" ] && refr_flag="--referrer=$generic_refr"
    ! (printf '%s' "$result" | grep -q "cc>") && unset subs_flag
}

decode_tobeparsed() {
    tmp="$(mktemp)"
    printf '%s' "$1" | base64 -d >"$tmp"
    iv="$(dd if="$tmp" bs=1 count=12 2>/dev/null | od -A n -t x1 | tr -d ' \n')"
    ctr="${iv}00000002"
    decode_key="${allanime_key:-$english_source_key}"
    plain="$(dd if="$tmp" bs=1 skip=12 2>/dev/null | openssl enc -d -aes-256-ctr -K "$decode_key" -iv "$ctr" -nosalt -nopad 2>/dev/null)"
    rm -f "$tmp"
    printf '%s' "$plain" | tr '{}' '\n' | sed -nE 's|.*"sourceUrl":"--([^"]*)".*"sourceName":"([^"]*)".*|\2 :\1|p'
}

get_episode_url() {
    animeflv_links=""
    jkanime_links=""
    animeav1_links=""
    unset selected_spanish_site selected_site selected_source selected_origin
    authoritative_site="$(site_name_from_ref "$id" 2>/dev/null || true)"
    authoritative_ep_list=""
    [ -n "$authoritative_site" ] && authoritative_ep_list="$(episodes_list_for_source "$authoritative_site" "$id" "$title")"
    [ -z "$authoritative_ep_list" ] && authoritative_ep_list="$ep_list"

    animeflv_id="$(show_ref_value_for_site "$id" "animeflv")"
    [ -z "$animeflv_id" ] && [ "$id" = "${id#*:}" ] && animeflv_id="$id"
    [ -z "$animeflv_id" ] && animeflv_id="$(select_animeflv_id "$title")"
    if [ -n "$animeflv_id" ]; then
        episode_page="$(animeflv_request "${allanime_refr}/ver/${animeflv_id}-${ep_no}")" || episode_page=""
    else
        episode_page=""
    fi

    if [ -n "$episode_page" ]; then
        videos_json="$(printf '%s' "$episode_page" | tr '\n' ' ' | sed -nE 's|.*var videos = (\{.*\});[[:space:]]*// var videos.*|\1|p')"
        selected_lang="$(pick_animeflv_language "$videos_json")"
        if [ -n "$selected_lang" ]; then
            [ "$mode" = "dub" ] && [ "$selected_lang" = "SUB" ] && printf "No hay doblaje disponible en AnimeFLV, usando subtitulado\n" 1>&2
            animeflv_links="$(extract_animeflv_links "$videos_json" "$selected_lang" | sort -g -r -s)"
            animeflv_links="$(filter_playable_links "$animeflv_links")"
            animeflv_links="$(filter_links_by_episode_catalog "animeflv" "$animeflv_links" "$authoritative_site" "$authoritative_ep_list")"
        else
            printf "AnimeFLV sin idioma reproducible.\n" 1>&2
        fi
    elif [ -n "$animeflv_id" ]; then
        printf "AnimeFLV no respondio.\n" 1>&2
    fi

    jkanime_links="$(resolve_jkanime_episode "$title" "$ep_no" | sort -g -r -s)"
    jkanime_links="$(filter_playable_links "$jkanime_links")"
    jkanime_links="$(filter_links_by_episode_catalog "jkanime" "$jkanime_links" "$authoritative_site" "$authoritative_ep_list")"

    animeav1_links="$(resolve_animeav1_episode "$title" "$ep_no" | sort -g -r -s)"
    animeav1_links="$(filter_playable_links "$animeav1_links")"
    animeav1_links="$(filter_links_by_episode_catalog "animeav1" "$animeav1_links" "$authoritative_site" "$authoritative_ep_list")"

    if pick_spanish_source_links "$animeflv_links" "$jkanime_links" "$animeav1_links"; then
        [ -n "$selected_spanish_site" ] && printf "Fuente elegida: %s\n" "$selected_spanish_site" 1>&2
    else
        printf "Las fuentes en espanol no funcionaron. Probando fuente en ingles...\n" 1>&2
        links="$(resolve_allanime_episode "$title" "$ep_no" | sort -g -r -s)"
        links="$(filter_playable_links "$links")"
    fi
    select_quality "$quality"
    if printf "%s" "$ep_list" | grep -q "^$ep_no$"; then
        [ -z "$episode" ] && die "El episodio ya fue publicado, pero no se encontraron fuentes validas"
    else
        [ -z "$episode" ] && die "Episodio no disponible todavia"
    fi
}

search_anime_for_source() {
    case "$1" in
        animeflv)
            source_results="$(search_animeflv "$2")"
            [ -n "$source_results" ] && prefix_search_results "animeflv" "$source_results"
            ;;
        jkanime)
            source_results="$(search_jkanime "$2")"
            [ -n "$source_results" ] && prefix_search_results "jkanime" "$source_results"
            ;;
        animeav1)
            source_results="$(search_animeav1 "$2")"
            [ -n "$source_results" ] && prefix_search_results "animeav1" "$source_results"
            ;;
        allanime)
            fallback_query="$(printf '%s' "$2" | sed 's|+| |g')"
            source_results="$(search_allanime_catalog "$fallback_query")"
            [ -n "$source_results" ] && prefix_allanime_search_results "$source_results"
            ;;
    esac
}

search_anime() {
    if [ "$preferred_info_source" != "auto" ]; then
        search_anime_for_source "$preferred_info_source" "$1"
        return 0
    fi

    search_results=""
    animeflv_results="$(search_animeflv "$1")"
    [ -n "$animeflv_results" ] && search_results="${search_results}$(prefix_search_results "animeflv" "$animeflv_results")
"
    jkanime_results="$(search_jkanime "$1")"
    [ -n "$jkanime_results" ] && search_results="${search_results}$(prefix_search_results "jkanime" "$jkanime_results")
"

    animeav1_results="$(search_animeav1 "$1")"
    [ -n "$animeav1_results" ] && search_results="${search_results}$(prefix_search_results "animeav1" "$animeav1_results")
"

    if [ -n "$search_results" ]; then
        printf '%s' "$search_results" | sed '/^$/d'
        return 0
    fi

    fallback_query="$(printf '%s' "$1" | sed 's|+| |g')"
    allanime_results="$(search_allanime_catalog "$fallback_query")"
    [ -n "$allanime_results" ] && prefix_allanime_search_results "$allanime_results"
}

time_until_next_ep() {
    animeschedule="https://animeschedule.net"
    query="$(printf "%s\n" "$*" | tr ' ' '+')"
    curl -s -G "$animeschedule/api/v3/anime" --data "q=${query}" | sed 's|"id"|\n|g' | sed -nE 's|.*,"route":"([^"]*)","premier.*|\1|p' | while read -r anime; do
        data=$(curl -s "$animeschedule/anime/$anime" | sed '1,/"anime-header-list-buttons-wrapper"/d' | sed -nE 's|.*countdown-time-raw" datetime="([^"]*)">.*|Next Raw Release: \1|p;s|.*countdown-time" datetime="([^"]*)">.*|Next Sub Release: \1|p;s|.*english-title">([^<]*)<.*|English Title: \1|p;s|.*main-title".*>([^<]*)<.*|Japanese Title: \1|p')
        status="Ongoing"
        color="33"
        printf "%s\n" "$data"
        ! (printf "%s\n" "$data" | grep -q "Next Raw Release:") && status="Finished" && color="32"
        printf "Status:  \033[1;%sm%s\033[0m\n---\n" "$color" "$status"
    done
    exit 0
}

# get the episodes list of the selected anime
episodes_list_animeflv() {
    animeflv_request "${allanime_refr}/anime/$*" | tr '\n' ' ' |
        sed -nE 's|.*var episodes = \[(.*)\];.*|\1|p' |
        sed 's|],\[|]\n[|g; s|\[||g; s|\]||g' | cut -d, -f1 | sort -n -k 1
}

episodes_list_animeav1() {
    animeav1_match="$(show_ref_value_for_site "$1" "animeav1")"
    [ -z "$animeav1_match" ] && animeav1_match="$(select_animeav1_slug "$2")"
    [ -z "$animeav1_match" ] && return 1

    animeav1_page="$(animeav1_request "${animeav1_refr}/media/${animeav1_match}")" || return 1
    printf '%s' "$animeav1_page" | tr '\n' ' ' |
        grep -oE 'number:[0-9]+(\.[0-9]+)?' | cut -d: -f2 | awk '!seen[$0]++' | sort -n -k 1
}

jkanime_page_anime_id() {
    printf '%s' "$1" | tr '\n' ' ' |
        sed -nE "s|.*anime_checks\\('[^']*', '([0-9]+)'.*|\\1|p" | head -n1
}

jkanime_page_csrf_token() {
    printf '%s' "$1" | tr '\n' ' ' |
        sed -nE 's|.*<meta name="csrf-token" content="([^"]+)".*|\1|p' | head -n1
}

jkanime_ajax_episode_numbers() {
    slug="$1"
    cookie_jar="$(mktemp)"
    page_html="$(curl -L --connect-timeout 10 --max-time "$resolver_timeout" -s -c "$cookie_jar" "${jkanime_refr}/${slug}/" -A "$agent")" || {
        rm -f "$cookie_jar"
        return 1
    }

    anime_id="$(jkanime_page_anime_id "$page_html")"
    csrf_token="$(jkanime_page_csrf_token "$page_html")"
    if [ -z "$anime_id" ] || [ -z "$csrf_token" ]; then
        rm -f "$cookie_jar"
        return 1
    fi

    first_page="$(curl -L --connect-timeout 10 --max-time "$resolver_timeout" -s -b "$cookie_jar" -c "$cookie_jar" \
        -X POST "${jkanime_refr}/ajax/episodes/${anime_id}/1" --data "_token=${csrf_token}" \
        -H "X-Requested-With: XMLHttpRequest" -A "$agent")" || {
        rm -f "$cookie_jar"
        return 1
    }

    last_page="$(printf '%s' "$first_page" | sed -nE 's|.*"last_page":([0-9]+).*|\1|p' | head -n1)"
    [ -z "$last_page" ] && last_page=1

    episode_numbers="$(printf '%s' "$first_page" | grep -oE '"number":[0-9]+(\.[0-9]+)?' | cut -d: -f2)"
    page_no=2
    while [ "$page_no" -le "$last_page" ]; do
        page_json="$(curl -L --connect-timeout 10 --max-time "$resolver_timeout" -s -b "$cookie_jar" -c "$cookie_jar" \
            -X POST "${jkanime_refr}/ajax/episodes/${anime_id}/${page_no}" --data "_token=${csrf_token}" \
            -H "X-Requested-With: XMLHttpRequest" -A "$agent")" || break
        episode_numbers="${episode_numbers}
$(printf '%s' "$page_json" | grep -oE '\"number\":[0-9]+(\.[0-9]+)?' | cut -d: -f2)"
        page_no=$((page_no + 1))
    done

    rm -f "$cookie_jar"
    printf '%s\n' "$episode_numbers" | sed '/^$/d' | awk '!seen[$0]++' | sort -n -k 1
}

episodes_list_jkanime() {
    jkanime_match="$(show_ref_value_for_site "$1" "jkanime")"
    [ -z "$jkanime_match" ] && jkanime_match="$(select_jkanime_slug "$2")"
    [ -z "$jkanime_match" ] && return 1

    ajax_episode_numbers="$(jkanime_ajax_episode_numbers "$jkanime_match")"
    [ -n "$ajax_episode_numbers" ] && printf '%s\n' "$ajax_episode_numbers" && return 0

    jkanime_page="$(jkanime_request "${jkanime_refr}/${jkanime_match}/")" || return 1
    latest_ep="$(printf '%s' "$jkanime_page" | tr '\n' ' ' |
        sed -nE "s|.*https://jkanime\\.net/${jkanime_match}/([0-9.]+)/.*id=\"uep\".*|\\1|p")"
    [ -z "$latest_ep" ] && latest_ep="$(printf '%s' "$jkanime_page" | tr '\n' ' ' |
        sed -nE "s|.*https://jkanime\\.net/${jkanime_match}/([0-9.]+)/.*|\\1|p")"
    [ -z "$latest_ep" ] && return 1

    case "$latest_ep" in
        *.*) printf '%s\n' "$latest_ep" ;;
        *) awk -v max="$latest_ep" 'BEGIN { for (i = 1; i <= max; i++) print i }' ;;
    esac
}

episodes_list_allanime() {
    episode_count="$(allanime_count_from_ref "$1")" || return 1
    [ -z "$episode_count" ] && return 1
    awk -v max="$episode_count" 'BEGIN { for (i = 1; i <= max; i++) print i }'
}

episodes_list_for_source() {
    case "$1" in
        animeflv)
            animeflv_id="$(show_ref_value_for_site "$2" "animeflv")"
            [ -z "$animeflv_id" ] && [ "$2" = "${2#*:}" ] && animeflv_id="$2"
            [ -z "$animeflv_id" ] && animeflv_id="$(select_animeflv_id "$3")"
            [ -n "$animeflv_id" ] && episodes_list_animeflv "$animeflv_id"
            ;;
        jkanime)
            episodes_list_jkanime "$2" "$3"
            ;;
        animeav1)
            episodes_list_animeav1 "$2" "$3"
            ;;
        allanime)
            allanime_ref="$(show_ref_value_for_site "$2" "allanime")"
            [ -z "$allanime_ref" ] && allanime_ref="$(select_allanime_ref "$3")"
            [ -n "$allanime_ref" ] && episodes_list_allanime "allanime:${allanime_ref}"
            ;;
    esac
}

latest_episode_number() {
    printf '%s\n' "$1" | sed '/^$/d' | tail -n1 | tr -d '[:space:]'
}

episode_number_delta() {
    awk -v a="$1" -v b="$2" 'BEGIN { diff = a - b; if (diff < 0) diff = -diff; printf "%d\n", diff }'
}

episode_catalog_matches_authoritative() {
    authoritative_list="$1"
    candidate_list="$2"

    [ -n "$candidate_list" ] || return 1
    [ -n "$authoritative_list" ] || return 0

    authoritative_latest="$(latest_episode_number "$authoritative_list")"
    candidate_latest="$(latest_episode_number "$candidate_list")"
    [ -n "$authoritative_latest" ] || return 0
    [ -n "$candidate_latest" ] || return 0

    case "$authoritative_latest:$candidate_latest" in
        *[!0-9.:]*)
            [ -n "$ep_no" ] && printf '%s\n' "$candidate_list" | grep -qx "$ep_no"
            return $?
            ;;
    esac

    [ -n "$ep_no" ] && ! printf '%s\n' "$candidate_list" | grep -qx "$ep_no" && return 1
    delta="$(episode_number_delta "$authoritative_latest" "$candidate_latest")"
    [ "$delta" -le 2 ]
}

filter_links_by_episode_catalog() {
    site_name="$1"
    site_links="$2"
    authoritative_site="$3"
    authoritative_list="$4"

    [ -n "$site_links" ] || return 1
    [ -z "$authoritative_site" ] && printf '%s' "$site_links" && return 0
    [ "$site_name" = "$authoritative_site" ] && printf '%s' "$site_links" && return 0

    candidate_list="$(episodes_list_for_source "$site_name" "$id" "$title")"
    if episode_catalog_matches_authoritative "$authoritative_list" "$candidate_list"; then
        printf '%s' "$site_links"
    else
        printf "Descartando %s: catalogo no coincide con %s\n" "$(info_source_label "$site_name")" "$(info_source_label "$authoritative_site")" 1>&2
        return 1
    fi
}

episodes_list() {
    if [ "$preferred_info_source" != "auto" ]; then
        episodes="$(episodes_list_for_source "$preferred_info_source" "$1" "$2")"
        [ -n "$episodes" ] && printf '%s\n' "$episodes"
        return 0
    fi

    selected_site="$(site_name_from_ref "$1" 2>/dev/null || true)"
    episodes=""
    for site_name in "$selected_site" animeflv animeav1 jkanime allanime; do
        [ -n "$site_name" ] || continue
        [ -n "$episodes" ] && break
        episodes="$(episodes_list_for_source "$site_name" "$1" "$2")"
    done
    [ -n "$episodes" ] && printf '%s\n' "$episodes"
}

# PLAYING

process_hist_entry() {
    ep_list=$(episodes_list "$id" "$title")
    latest_ep=$(printf "%s\n" "$ep_list" | tail -n1)
    title=$(printf "%s\n" "$title" | sed "s|[0-9]\+ episodios|${latest_ep} episodios|")
    ep_no=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{n;p;}") 2>/dev/null
    [ -n "$ep_no" ] && printf "%s\t%s - episodio %s\n" "$id" "$title" "$ep_no"
}

update_history() {
    awk -F '	' -v OFS='	' -v target="$id" -v new_ep="$ep_no" -v new_title="$title" '
        BEGIN { updated = 0 }
        $2 == target {
            $1 = new_ep
            $3 = new_title
            updated = 1
        }
        NF { print }
        END {
            if (!updated) {
                print new_ep, target, new_title
            }
        }
    ' "$histfile" >"${histfile}.new"
    mv "${histfile}.new" "$histfile"
}

download() {
    # download subtitle if it's set
    [ -n "$subtitle" ] && curl -s "$subtitle" -o "$download_dir/$2.vtt"
    case $1 in
        *m3u8*)
            if command -v "yt-dlp" >/dev/null; then
                yt-dlp --referer "$m3u8_refr" "$1" --no-skip-unavailable-fragments --fragment-retries infinite -N 16 -o "$download_dir/$2.mp4"
            else
                ffmpeg -extension_picky 0 -referer "$m3u8_refr" -loglevel error -stats -i "$1" -c copy "$download_dir/$2.mp4"
            fi
            # embed subs into downloads
            # [ -e "$download_dir/$2.vtt" ] && ffmpeg -i "$download_dir/$2.mp4" -i "$download_dir/$2.vtt" -c copy -c:s mov_text "$download_dir/$2.bak.mp4" && mv "$download_dir/$2.bak.mp4" "$download_dir/$2.mp4"
            ;;
        *)
            # shellcheck disable=SC2086
            aria2c --referer="$allanime_refr" --enable-rpc=false --check-certificate=false --continue $iSH_DownFix --summary-interval=0 -x 16 -s 16 "$1" --dir="$download_dir" -o "$2.mp4" --download-result=hide
            ;;
    esac
}

play_episode() {
    manual_handoff=0
    [ "$log_episode" = 1 ] && [ "$player_function" != "debug" ] && [ "$player_function" != "download" ] && command -v logger >/dev/null && logger -t "$log_tag" "${allanime_title}${ep_no}"
    [ "$skip_intro" = 1 ] && skip_flag="$(ani-skip -q "$mal_id" -e "$ep_no")"
    [ -z "$episode" ] && get_episode_url
    if [ "$selected_source" = "HQQ" ] && [ "$hqq_browser_fallback" = "1" ] &&
        [ -n "$generic_refr" ] && [ "$player_function" != "debug" ] && [ "$player_function" != "download" ]; then
        printf "Fuente seleccionada: %s\n" "${selected_origin:-$selected_source}" 1>&2
        printf "HQQ requiere desbloqueo manual.\n" 1>&2
        printf "Abre esta URL:\n%s\n" "$generic_refr" 1>&2
        if open_browser_url "$generic_refr"; then
            printf "Abriendo navegador...\n" 1>&2
        fi
        manual_handoff=1
    fi
    # shellcheck disable=SC2086
    case "$player_function" in
        debug)
            printf "Todos los enlaces:\n%s\nFuente seleccionada:\n%s\n" "$links" "${selected_origin:-desconocida}"
            [ "$selected_source" = "HQQ" ] && [ -n "$generic_refr" ] && printf "Accion manual HQQ:\n%s\n" "$generic_refr"
            printf "Enlace seleccionado:\n"
            printf "%s\n" "$episode"
            ;;
        mpv*)
            [ -n "$selected_origin" ] && [ "$manual_handoff" = 0 ] && printf "Fuente seleccionada: %s\n" "$selected_origin" 1>&2
            if [ "$manual_handoff" = 1 ]; then
                :
            elif [ "$no_detach" = 0 ]; then
                nohup $player_function $skip_flag --force-media-title="${allanime_title}Episode ${ep_no}" "$episode" $subs_flag $refr_flag >/dev/null 2>&1 &
            else
                $player_function $skip_flag $subs_flag $refr_flag --force-media-title="${allanime_title}Episode ${ep_no}" "$episode"
                mpv_exitcode=$?
                [ "$exit_after_play" = 1 ] && [ -z "$range" ] && exit "$mpv_exitcode"
            fi
            ;;
        android_mpv) nohup am start --user 0 -a android.intent.action.VIEW -d "$episode" -n is.xyz.mpv/.MPVActivity >/dev/null 2>&1 & ;;
        android_vlc) nohup am start --user 0 -a android.intent.action.VIEW -d "$episode" -n org.videolan.vlc/org.videolan.vlc.gui.video.VideoPlayerActivity -e "title" "${allanime_title}Episode ${ep_no}" >/dev/null 2>&1 & ;;
        *iina*)
            [ -n "$subs_flag" ] && subs_flag="--mpv-${subs_flag#--}"
            [ -n "$refr_flag" ] && refr_flag="--mpv-${refr_flag#--}"
            if pgrep -f "IINA" >/dev/null 2>&1; then
                # omit --keep-running when an IINA instance exists to prevent hanging
                nohup $player_function --no-stdin --mpv-force-media-title="${allanime_title}Episode ${ep_no}" $subs_flag $refr_flag "$episode" >/dev/null 2>&1 &
            else
                nohup $player_function --no-stdin --keep-running --mpv-force-media-title="${allanime_title}Episode ${ep_no}" $subs_flag $refr_flag "$episode" >/dev/null 2>&1 &
            fi
            ;;
        flatpak_mpv) flatpak run io.mpv.Mpv --force-media-title="${allanime_title}Episode ${ep_no}" "$episode" $subs_flag $refr_flag >/dev/null 2>&1 & ;;
        vlc*) nohup $player_function --http-referrer="${allanime_refr}" --play-and-exit --meta-title="${allanime_title}Episode ${ep_no}" "$episode" >/dev/null 2>&1 & ;;
        *yncpla*) nohup $player_function "$episode" -- --force-media-title="${allanime_title}Episode ${ep_no}" $subs_flag $refr_flag >/dev/null 2>&1 & ;;
        download) "$player_function" "$episode" "${allanime_title}Episode ${ep_no}" "$subtitle" ;;
        catt) nohup catt cast "$episode" -s "$subtitle" >/dev/null 2>&1 & ;;
        iSH)
            printf "\e]8;;vlc://%s\a~~~~~~~~~~~~~~~~~~~~\n~ Tap to open VLC ~\n~~~~~~~~~~~~~~~~~~~~\e]8;;\a\n" "$episode"
            sleep 5
            ;;
        *) nohup $player_function "$episode" >/dev/null 2>&1 & ;;
    esac
    replay="$episode"
    unset episode
    [ "$manual_handoff" = 1 ] || update_history
    [ "$manual_handoff" = 1 ] && [ "$exit_after_play" = 1 ] && [ -z "$range" ] && exit 0
    [ "$use_external_menu" = "1" ] && wait
    [ "$use_external_menu" = "2" ] && wait
}

play() {
    start=$(printf "%s" "$ep_no" | grep -Eo '^(-1|[0-9]+(\.[0-9]+)?)')
    end=$(printf "%s" "$ep_no" | grep -Eo '(-1|[0-9]+(\.[0-9]+)?)$')
    [ "$start" = "-1" ] && ep_no=$(printf "%s" "$ep_list" | tail -n1) && unset start
    [ -z "$end" ] || [ "$end" = "$start" ] && unset start end
    [ "$end" = "-1" ] && end=$(printf "%s" "$ep_list" | tail -n1)
    line_count=$(printf "%s\n" "$ep_no" | wc -l | tr -d "[:space:]")
    if [ "$line_count" != 1 ] || [ -n "$start" ]; then
        [ -z "$start" ] && start=$(printf "%s\n" "$ep_no" | head -n1)
        [ -z "$end" ] && end=$(printf "%s\n" "$ep_no" | tail -n1)
        range=$(printf "%s\n" "$ep_list" | sed -nE "/^${start}\$/,/^${end}\$/p")
        [ -z "$range" ] && die "Invalid range!"
        for i in $range; do
            tput clear
            ep_no=$i
            printf "\33[2K\r\033[1;34mReproduciendo episodio %s...\033[0m\n" "$ep_no"
            [ "$i" = "$end" ] && unset range
            play_episode
        done
    else
        play_episode
    fi
    # moves up to stored position and deletes to end
    [ "$player_function" != "debug" ] && [ "$player_function" != "download" ] && tput rc && tput ed
}

