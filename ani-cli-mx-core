        "" | auto) printf '%s\n' "auto" ;;
        animeflv | flv) printf '%s\n' "animeflv" ;;
        jkanime | jk) printf '%s\n' "jkanime" ;;
        animeav1 | av1) printf '%s\n' "animeav1" ;;
        allanime | allmanga | english) printf '%s\n' "allanime" ;;
        *) return 1 ;;
    esac
}

info_source_label() {
    case "$1" in
        auto) printf '%s\n' "Auto" ;;
        animeflv) printf '%s\n' "AnimeFLV" ;;
        jkanime) printf '%s\n' "JKAnime" ;;
        animeav1) printf '%s\n' "AnimeAV1" ;;
        allanime) printf '%s\n' "AllManga" ;;
        *) printf '%s\n' "$1" ;;
    esac
}

source_label() {
    case "$1" in
        sw) printf '%s' "StreamWish" ;;
        stape) printf '%s' "Streamtape" ;;
        netu) printf '%s' "HQQ" ;;
        mega) printf '%s' "Mega" ;;
        yu) printf '%s' "YourUpload" ;;
        okru) printf '%s' "Okru" ;;
        fembed) printf '%s' "Fembed" ;;
